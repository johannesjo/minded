{
  "name": "minded",
  "version": "1.0.0",
  "description": "minded",
  "main": "index.js",
  "scripts": {
    "start": "NODE_ENV=development vite build --watch",
    "dev": "vite",
    "serve": "vite preview",
    "build": "vite build && npm run pack",
    "pack": "rm minded.zip; cd dist && zip -r ../minded.zip .",
    "clean": "rimraf dist",
    "style": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "author": "Johannes Millan",
  "repository": {
    "type": "git",
    "url": "https://github.com/johannesjo/minded"
  },
  "type": "module",
  "dependencies": {
    "parse-domain": "^5.0.0",
    "solid-js": "^1.8.15",
    "webextension-polyfill": "^0.10.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@types/chrome": "0.0.262",
    "@types/webextension-polyfill": "^0.10.7",
    "hot-reload-extension-vite": "^1.0.13",
    "prettier": "3.2.5",
    "rimraf": "^5.0.5",
    "sass": "^1.70.0",
    "solid-devtools": "^0.29.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-solid": "^2.8.2",
    "vite-plugin-static-copy": "^1.0.1"
  }
