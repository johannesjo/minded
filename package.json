{
  "name": "minded",
  "version": "1.0.0",
  "description": "'minded' is a tool that will help you to be more productive and focused on what counts.",
  "main": "index.js",
  "scripts": {
    "start": "NODE_ENV=development npm run dev",
    "dev": "vite build -w",
    "serve": "vite preview",
    "lint": "eslint . --fix -c .eslintrc --ext js,ts --ignore-pattern='!.*'",
    "build": "vite build && npm run pack",
    "pack": "rm minded.zip; cd dist && zip -r ../minded.zip .",
    "clean": "rimraf dist",
    "test": "jest",
    "dev:nodemon": "nodemon"
  },
  "author": "Johannes Millan",
  "repository": {
    "type": "git",
    "url": "https://github.com/johannesjo/minded"
  },
  "type": "module",
  "dependencies": {
    "nanoid": "^5.0.6",
    "parse-domain": "^8.0.2",
    "solid-js": "^1.8.15",
    "webextension-polyfill": "^0.10.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@types/chrome": "0.0.262",
    "@types/webextension-polyfill": "^0.10.7",
    "eslint": "8.57.0",
    "jest": "^29.7.0",
    "nodemon": "3.1.0",
    "prettier": "3.2.5",
    "rimraf": "^5.0.5",
    "sass": "^1.70.0",
    "solid-devtools": "^0.29.2",
    "ts-jest": "^29.0.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-solid": "^2.8.2"
  }
}
