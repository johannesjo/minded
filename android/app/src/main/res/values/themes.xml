<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Minded" parent="android:Theme.Material.Light.NoActionBar" />
    <!-- windowBackground paints the loading sky on cold start (before the WebView
         draws) instead of white. Light is the day/default; at night the system
         picks the dark variant from values-night-v31, driven by the app's own
         clock (MindedApplication registers it via setApplicationNightMode) so the
         starting window itself arrives dark - see issue #117. On API < 31 there
         is no per-app override, so MainActivity's onCreate swap corrects the
         activity window instead. -->
    <style name="Theme.MindedAppCompat" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/loading_gradient_light</item>
    </style>
</resources>
