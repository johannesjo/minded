<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon MONOCHROME (Android 13+ themed icons): the app's resting sun
     as a single centred disc. The system ignores the fill colour and tints the
     shape by its alpha, so this is a flat silhouette. It mirrors the companion
     sun (ic_sun_widget_day.xml) - a centred disc - rather than the rising
     launcher sun, so the tinted glyph reads unmistakably as the sun and stays
     within the ~66dp safe zone (r=32 of the 108 grid) instead of bleeding off
     the bottom under the launcher mask. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
  <path
      android:pathData="M54,54 m-32,0 a32,32 0 1,0 64,0 a32,32 0 1,0 -64,0"
      android:fillColor="#FF000000"/>
</vector>
