<?xml version="1.0" encoding="utf-8"?>
<!--
  Dark cold-start window background. A pre-dithered bitmap of the exact app sky
  (see android/tools/gen_loading_sky.py) stretched to fill: it carries the full
  multi-stop gradient with the banding ("weird lines") already dithered away in
  the pixels, which an 8-bit <shape> gradient could neither approximate nor draw
  smoothly. The Compose Box / WebView paint the same image / the real web sky.
-->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@drawable/loading_sky_dark"
    android:gravity="fill" />
