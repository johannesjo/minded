<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="48"
    android:viewportHeight="48">
    <!--
      Crescent as a single filled region bounded by two arcs between the same two
      horn points (21.03,9.3) and (37.29,30.96): the outer back follows a r=15 disc
      (centered at 24,24), the belly follows a r=14 disc (centered at 32,18).
      Even-odd of two overlapping discs would draw their symmetric difference (a
      ring with a lens-shaped hole), not a crescent — hence the explicit arcs.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M21.03,9.3 A15,15 0 1 0 37.29,30.96 A14,14 0 0 1 21.03,9.3 Z" />
</vector>
