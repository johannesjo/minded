<!-- DAWN phase of the living companion sun: soft first light. A warm, near-white
     disc that fades to a gentle peach at the rim, in a low pink-gold glow — the
     quiet sun of early morning. Uses the app's warm ramp (toward #FFAE52), kept
     pale so it reads as rising, not blazing. See docs/sun-companion-widget.md. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:aapt="http://schemas.android.com/aapt"
        android:width="108dp"
        android:height="108dp"
        android:viewportWidth="108"
        android:viewportHeight="108">

    <!-- Soft pink-gold dawn glow, gentle and low-alpha -->
    <path android:pathData="M54,54 m-53,0 a53,53 0 1,0 106,0 a53,53 0 1,0 -106,0">
        <aapt:attr name="android:fillColor">
            <gradient
                    android:type="radial"
                    android:centerX="54"
                    android:centerY="54"
                    android:gradientRadius="53">
                <item android:offset="0.0" android:color="#00FFC89A" />
                <item android:offset="0.56" android:color="#00FFC89A" />
                <item android:offset="0.74" android:color="#47FFB985" />
                <item android:offset="1.0" android:color="#00FFAE6E" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- The disc: warm white centre fading to a soft peach rim -->
    <path android:pathData="M54,54 m-36,0 a36,36 0 1,0 72,0 a36,36 0 1,0 -72,0">
        <aapt:attr name="android:fillColor">
            <gradient
                    android:type="radial"
                    android:centerX="54"
                    android:centerY="54"
                    android:gradientRadius="36">
                <item android:offset="0.0" android:color="#FFFFFDF7" />
                <item android:offset="0.7" android:color="#FFFFE9CE" />
                <item android:offset="1.0" android:color="#FFFFC79A" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
