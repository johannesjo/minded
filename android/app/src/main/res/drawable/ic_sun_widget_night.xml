<!-- NIGHT phase of the living companion sun: the moon, matched to the app's `.moon`
     (radial: white highlight upper-left → #dfe8ff → #a9b8dc) with a soft cool halo.
     Picked by the local hour in MyAppWidget, not by the dark-mode qualifier — so
     it shows at actual night, not whenever the system theme is dark.
     See docs/sun-companion-widget.md. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:aapt="http://schemas.android.com/aapt"
        android:width="108dp"
        android:height="108dp"
        android:viewportWidth="108"
        android:viewportHeight="108">

    <!-- Soft cool glow -->
    <path android:pathData="M54,54 m-53,0 a53,53 0 1,0 106,0 a53,53 0 1,0 -106,0">
        <aapt:attr name="android:fillColor">
            <gradient
                    android:type="radial"
                    android:centerX="54"
                    android:centerY="54"
                    android:gradientRadius="53">
                <item android:offset="0.0" android:color="#00D8E5FF" />
                <item android:offset="0.62" android:color="#00D8E5FF" />
                <item android:offset="0.80" android:color="#29CFE0FF" />
                <item android:offset="1.0" android:color="#00B2CAFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- The moon disc, lit from the upper-left like the in-app moon -->
    <path android:pathData="M54,54 m-42,0 a42,42 0 1,0 84,0 a42,42 0 1,0 -84,0">
        <aapt:attr name="android:fillColor">
            <gradient
                    android:type="radial"
                    android:centerX="40"
                    android:centerY="37"
                    android:gradientRadius="62">
                <item android:offset="0.0" android:color="#FFFFFFFF" />
                <item android:offset="0.18" android:color="#FFFFFFFF" />
                <item android:offset="0.58" android:color="#FFDFE8FF" />
                <item android:offset="1.0" android:color="#FFA9B8DC" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
