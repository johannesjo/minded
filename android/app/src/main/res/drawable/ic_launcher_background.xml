<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon BACKGROUND: the pastel dawn sky, full-bleed. The sun disc
     lives in the foreground layer (ic_launcher_foreground.xml) so it gains
     parallax depth over this sky. Kept identical to the raster fallbacks
     (mipmap-*/ic_launcher.webp) and ic_launcher-playstore.png, so the visible
     icon is unchanged — this only moves the sky out of the foreground and
     retires the old Android Studio placeholder grid. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">
  <path android:pathData="M0,0h512v512h-512z">
    <aapt:attr name="android:fillColor">
      <gradient
          android:centerX="256"
          android:centerY="512"
          android:gradientRadius="512"
          android:tileMode="clamp"
          android:type="radial">
        <item android:offset="0.33" android:color="#FFEFEE9F"/>
        <item android:offset="0.66" android:color="#FFFFCCEA"/>
        <item android:offset="0.9" android:color="#FFAAE9EE"/>
      </gradient>
    </aapt:attr>
  </path>
</vector>
