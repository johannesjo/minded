{
  "manifest_version": 2,
  "name": "minded",
  "description": "minded xxx",
  "version": "0.0",
  "icons": {
    "128": "icon_128x128.png"
  },
  "options_ui": {
    "page": "options.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "minded@minded.app",
      "strict_min_version": "88.0"
    }
  },
  "browser_action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": [
      "js/background.js"
    ],
    "persistent": false
  },
  "content_scripts": [
    {
      "run_at": "document_start",
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "js/content-script.js"
      ]
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "<all_urls>"
  ]
}
