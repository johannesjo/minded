<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Export options for the App Store / TestFlight build (see
  .github/workflows/ios-testflight.yml). Signing is automatic ("cloud
  managed"): xcodebuild is invoked with -allowProvisioningUpdates and an
  App Store Connect API key, so Apple creates/downloads the distribution
  certificate and provisioning profile on the runner. No .p12 or
  .mobileprovision needs to live in CI.
-->
<plist version="1.0">
<dict>
  <key>method</key>
  <string>app-store</string>
  <key>teamID</key>
  <string>363FAFK383</string>
  <key>signingStyle</key>
  <string>automatic</string>
  <key>destination</key>
  <string>export</string>
  <key>uploadSymbols</key>
  <true/>
  <key>stripSwiftSymbols</key>
  <true/>
</dict>
</plist>
