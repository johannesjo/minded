{
  "name": "minded",
  "version": "5.0.7",
  "description": "'minded' will help you fight social media addiction, doom-scrolling and procrastination and to focus on what really counts.",
  "main": "index.js",
  "scripts": {
    "start": "NODE_ENV=development npm run dev",
    "startDroid": "NODE_ENV=development vite build -w --mode android --emptyOutDir",
    "startIOS": "NODE_ENV=development vite build -w --mode ios --emptyOutDir",
    "styleguide": "NODE_ENV=development vite build --mode styleguide && NODE_ENV=development vite preview --mode styleguide --port 5174",
    "dev": "vite build -w",
    "serve": "vite preview",
    "lint": "eslint .. --fix -c .eslintrc --ext js,ts --ignore-pattern='!.*'",
    "screenshots": "node scripts/create-screenshots.mjs",
    "screenshots:install": "playwright install chromium",
    "build": "vite build && npm run pack",
    "buildDroid": "vite build --mode android --emptyOutDir",
    "buildIOS": "vite build --mode ios --emptyOutDir && npx cap sync",
    "pack": "rm minded.zip; cd dist && zip -r ../minded.zip .",
    "clean": "rimraf dist",
    "test": "jest",
    "test:android": "cd ../android && ./gradlew testDebugUnitTest --console=plain",
    "dev:nodemon": "nodemon",
    "preversion": "node scripts/preversion.mjs",
    "version": "node scripts/sync-platforms.mjs",
    "postversion": "node scripts/postversion.mjs"
  },
  "author": "Johannes Millan",
  "repository": {
    "type": "git",
    "url": "https://github.com/johannesjo/minded"
  },
  "type": "module",
  "dependencies": {
    "@capacitor/android": "^7.4.0",
    "@capacitor/core": "^7.4.0",
    "@capacitor/ios": "^7.4.0",
    "@capacitor/keyboard": "^7.0.1",
    "@capacitor/preferences": "^7.0.1",
    "@solidjs/router": "^0.13.3",
    "capacitor-plugin-safe-area": "^4.0.0",
    "chart.js": "^4.5.0",
    "nanoid": "^5.1.5",
    "parse-domain": "^8.2.2",
    "solid-chartjs": "^1.3.11",
    "solid-js": "^1.9.7",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.0",
    "@crxjs/vite-plugin": "^2.0.2",
    "@types/chrome": "0.0.328",
    "@types/jest": "^30.0.0",
    "@types/webextension-polyfill": "^0.12.3",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-solid": "^0.14.5",
    "jest": "^30.0.3",
    "nodemon": "3.1.10",
    "playwright": "^1.60.0",
    "prettier": "3.6.2",
    "rimraf": "^6.0.1",
    "rollup-plugin-copy": "^3.5.0",
    "sass": "^1.89.2",
    "solid-devtools": "^0.34.2",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-solid": "^2.11.7"
  }
}
