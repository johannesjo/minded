{
  "name": "minded",
  "version": "1.3.0",
  "description": "'minded' will help you fight social media addiction, doom-scrolling and procrastination and to focus on what really counts.",
  "main": "index.js",
  "scripts": {
    "start": "NODE_ENV=development npm run dev",
    "startDroid": "NODE_ENV=development vite build -w --mode android",
    "dev": "vite build -w",
    "serve": "vite preview",
    "lint": "eslint .. --fix -c .eslintrc --ext js,ts --ignore-pattern='!.*'",
    "build": "vite build && npm run pack",
    "buildDroid": "vite build --mode android && /bin/rm -rf ../android/app/src/main/assets/web/*;  /bin/cp -r distDroid/* ../../AndroidStudioProjects/Minded/app/src/main/assets/web",
    "pack": "rm minded.zip; cd dist && zip -r ../minded.zip .",
    "clean": "rimraf dist",
    "test": "jest",
    "dev:nodemon": "nodemon"
  },
  "author": "Johannes Millan",
  "repository": {
    "type": "git",
    "url": "https://github.com/johannesjo/minded"
  },
  "type": "module",
  "dependencies": {
    "@solidjs/router": "^0.13.3",
    "chart.js": "^4.4.2",
    "nanoid": "^5.0.6",
    "parse-domain": "^8.0.2",
    "solid-chartjs": "^1.3.9",
    "solid-js": "^1.8.15",
    "webextension-polyfill": "^0.10.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@types/chrome": "0.0.262",
    "@types/webextension-polyfill": "^0.10.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-solid": "^0.13.2",
    "jest": "^29.7.0",
    "nodemon": "3.1.0",
    "prettier": "3.2.5",
    "rimraf": "^5.0.5",
    "sass": "^1.70.0",
    "solid-devtools": "^0.29.2",
    "ts-jest": "^29.0.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-solid": "^2.8.2"
  }
}
