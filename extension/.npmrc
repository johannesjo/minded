# Disable npm's built-in commit + tag step during `npm version`.
#
# npm v10 silently skipped commit + tag in this repo (postversion ran
# but no commit was made). Suspected root cause: the version hook stages
# files outside the package directory (android/ and extension/ios/),
# which npm's commit logic abandons on. Rather than chase the npm bug,
# scripts/postversion.mjs does commit + tag explicitly.
#
# See docs/release-automation-plan.md → "Release commit + tag".
git-tag-version=false
